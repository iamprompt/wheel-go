{
  "name": "wheel-go",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,md}\"",
    "prepare": "husky install",
    "dev:admin": "turbo run dev --filter=admin-dashboard --filter=ui",
    "dev:app": "turbo run dev --filter=app --filter=ui"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "turbo run lint -- --fix"
  },
  "devDependencies": {
    "eslint-config-wheel-go": "workspace:*",
    "husky": "^8.0.3",
    "lint-staged": "^13.1.2",
    "prettier": "^2.8.4",
    "turbo": "^1.8.1"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "packageManager": "pnpm@7.27.0"
}
