{
  "name": "@wheel-go/app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
    "dev": "vite --host 0.0.0.0 --port 3001 --clearScreen false",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx ./src",
    "ionic:serve": "vite --clearScreen false",
    "ionic:build": "tsc && vite build",
    "dev:ios": "ionic cap run ios --livereload --external",
    "dev:android": "ionic cap run android --livereload --external",
    "build:android": "ionic cap build android"
  },
  "dependencies": {
    "@capacitor/android": "^4.6.3",
    "@capacitor/app": "4.1.1",
    "@capacitor/core": "^4.6.3",
    "@capacitor/haptics": "4.1.0",
    "@capacitor/ios": "^4.6.3",
    "@capacitor/keyboard": "^4.1.1",
    "@capacitor/status-bar": "4.1.1",
    "@wheel-go/tsconfig": "workspace:^0.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^4.6.3",
    "@headlessui/react": "^1.7.10",
    "@iconify-json/material-symbols": "^1.1.29",
    "@iconify/icons-material-symbols": "^1.2.27",
    "@ionic/cli": "^6.20.8",
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@vitejs/plugin-react": "^3.1.0",
    "@wheel-go/tailwind-config": "workspace:^0.0.0",
    "autoprefixer": "^10.4.13",
    "eslint": "^8.33.0",
    "eslint-config-wheel-go": "workspace:^0.0.0",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.2.6",
    "typescript": "^4.9.5",
    "unplugin-icons": "^0.15.3",
    "vite": "^4.1.1",
    "vite-plugin-svgr": "^2.4.0",
    "vite-tsconfig-paths": "^4.0.5"
  }
}
